# 复制为 .env 并填入实际值

# ============ JWT 配置 ============
# 生产环境务必替换为强随机字符串（建议 openssl rand -hex 32）
JWT_SECRET_KEY=change-this-to-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ============ LLM 配置（OpenAI 兼容接口） ============
# 支持 OpenAI / DeepSeek / 本地 Ollama 等任意兼容服务
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o-mini

# ============ Redis ============
REDIS_URL=redis://localhost:6379/0

# ============ SQLite ============
DATABASE_URL=sqlite+aiosqlite:///./data/docqa.db

# ============ ChromaDB ============
CHROMA_PERSIST_DIR=./data/chroma_db

# ============ 本地模型路径 ============
EMBEDDING_MODEL_PATH=./models/bge-m3
RERANK_MODEL_PATH=./models/bge-reranker-v2-m3

# ============ 分块参数 ============
CHUNK_SIZE=500
CHUNK_OVERLAP=100
# 分块策略：fixed（定长滑窗）| markdown（标题感知两阶段）| recursive（递归分隔符，默认）
SPLIT_STRATEGY=recursive

# ============ 检索参数 ============
RETRIEVE_TOP_K=20
RERANK_TOP_K=3

# ============ 缓存参数 ============
CACHE_TTL_SECONDS=1800
CACHE_NULL_TTL_SECONDS=60
